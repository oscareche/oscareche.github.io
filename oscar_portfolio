<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Oscar Eche | Data Analyst Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #12121a;
    --surface-hover: #1a1a26;
    --border: #1e1e2e;
    --text: #e4e4e8;
    --text-muted: #8888a0;
    --accent: #4a7cff;
    --accent-glow: rgba(74, 124, 255, 0.15);
    --danger: #ff4a4a;
    --success: #4aff8b;
    --warning: #ffb84a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* Grain overlay */
  body::after {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
  }

  /* Navigation */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    padding: 1.2rem 2rem;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  nav .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  nav .logo span { color: var(--accent); }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  nav ul li a {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  nav ul li a:hover { color: var(--accent); }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 4rem;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }

  .hero-content { max-width: 700px; }

  .hero-tag {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--accent-glow);
    border: 1px solid rgba(74, 124, 255, 0.3);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.8rem;
    animation: fadeInUp 0.6s ease both;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 6vw, 4.2rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.6s ease 0.1s both;
  }

  .hero h1 .highlight {
    background: linear-gradient(135deg, var(--accent), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 540px;
    margin-bottom: 2.5rem;
    animation: fadeInUp 0.6s ease 0.2s both;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease 0.3s both;
  }

  .hero-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: #3a6cef;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(74, 124, 255, 0.3);
  }

  .btn-outline {
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  /* Glow orb */
  .hero-glow {
    position: absolute;
    right: -100px;
    top: 50%;
    transform: translateY(-50%);
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(74, 124, 255, 0.08) 0%, transparent 70%);
    pointer-events: none;
    animation: pulse 6s ease-in-out infinite;
  }

  /* Sections */
  section {
    padding: 6rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    letter-spacing: -0.02em;
    margin-bottom: 3rem;
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.2rem;
  }

  .skill-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.8rem;
    transition: all 0.3s;
  }

  .skill-card:hover {
    border-color: rgba(74, 124, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .skill-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .skill-card .icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
  }

  .skill-card p {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .skill-tags span {
    padding: 0.25rem 0.7rem;
    background: rgba(74, 124, 255, 0.08);
    border: 1px solid rgba(74, 124, 255, 0.15);
    border-radius: 100px;
    font-size: 0.75rem;
    color: var(--accent);
  }

  /* Projects */
  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 2rem;
    transition: all 0.3s;
  }

  .project-card:hover {
    border-color: rgba(74, 124, 255, 0.3);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .project-header {
    padding: 2.5rem 2.5rem 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .project-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .status-complete {
    background: rgba(74, 255, 139, 0.1);
    border: 1px solid rgba(74, 255, 139, 0.2);
    color: var(--success);
  }

  .status-progress {
    background: rgba(255, 184, 74, 0.1);
    border: 1px solid rgba(255, 184, 74, 0.2);
    color: var(--warning);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }

  .project-body { padding: 1.5rem 2.5rem 2rem; }

  .project-body h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    margin-bottom: 0.8rem;
    letter-spacing: -0.02em;
  }

  .project-body .description {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    max-width: 680px;
  }

  .project-stats {
    display: flex;
    gap: 2.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .project-stats .stat {
    display: flex;
    flex-direction: column;
  }

  .project-stats .stat-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent);
  }

  .project-stats .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .project-findings {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .finding {
    padding: 1rem;
    background: rgba(74, 124, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .finding strong {
    color: var(--text);
    display: block;
    margin-bottom: 0.3rem;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.8rem;
  }

  .project-tech span {
    padding: 0.3rem 0.8rem;
    background: var(--surface-hover);
    border-radius: 6px;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .project-links {
    display: flex;
    gap: 0.8rem;
  }

  .project-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s;
  }

  /* Placeholder project */
  .project-placeholder {
    border-style: dashed;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    cursor: default;
  }

  .project-placeholder:hover {
    border-color: var(--border);
    box-shadow: none;
  }

  .placeholder-content {
    text-align: center;
    padding: 2rem;
  }

  .placeholder-content .icon-large {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    opacity: 0.3;
  }

  .placeholder-content h3 {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .placeholder-content p {
    font-size: 0.85rem;
    color: rgba(136, 136, 160, 0.6);
  }

  /* Contact */
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text);
    transition: all 0.3s;
  }

  .contact-card:hover {
    border-color: rgba(74, 124, 255, 0.3);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .contact-card .label {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .contact-card .value {
    font-size: 0.92rem;
    font-weight: 500;
  }

  /* Footer */
  footer {
    padding: 3rem 2rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.8rem;
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }

  /* Animations */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: translateY(-50%) scale(1); }
    50% { opacity: 0.8; transform: translateY(-50%) scale(1.05); }
  }

  /* Scroll animations */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 768px) {
    nav ul { display: none; }
    .hero { padding: 7rem 1.5rem 3rem; }
    section { padding: 4rem 1.5rem; }
    .project-header { padding: 1.5rem 1.5rem 0; }
    .project-body { padding: 1rem 1.5rem 1.5rem; }
    .project-stats { gap: 1.5rem; }
  }
</style>
</head>
<body>

<nav>
  <div class="logo">Oscar<span>.</span></div>
  <ul>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-tag">Data Analyst</div>
    <h1>Turning raw data into <span class="highlight">business decisions</span></h1>
    <p>Data analyst with a background in operations and UX design. I use SQL, Google Sheets, and Power BI to find patterns in messy data and turn them into clear, actionable recommendations.</p>
    <div class="hero-links">
      <a href="#projects" class="btn-primary">View projects ↓</a>
      <a href="https://github.com/oscareche" target="_blank" class="btn-outline">GitHub ↗</a>
      <a href="https://linkedin.com/in/oscareche" target="_blank" class="btn-outline">LinkedIn ↗</a>
    </div>
  </div>
  <div class="hero-glow"></div>
</section>

<!-- Skills -->
<section id="skills">
  <div class="section-label reveal">Toolkit</div>
  <h2 class="section-title reveal">Skills &amp; tools</h2>
  <div class="skills-grid">
    <div class="skill-card reveal">
      <h3><span class="icon" style="background:rgba(74,124,255,0.1)">📊</span> Data Analysis</h3>
      <p>Segmentation, cross-referencing, descriptive statistics, trend identification, and translating findings into business recommendations.</p>
      <div class="skill-tags">
        <span>Google Sheets</span>
        <span>COUNTIFS</span>
        <span>Pivot Tables</span>
        <span>Power BI</span>
      </div>
    </div>
    <div class="skill-card reveal">
      <h3><span class="icon" style="background:rgba(139,92,246,0.1)">🗄️</span> SQL &amp; Databases</h3>
      <p>Writing queries to extract, filter, join, and aggregate data from relational databases. Comfortable with multi-table joins and subqueries.</p>
      <div class="skill-tags">
        <span>SQL</span>
        <span>BigQuery</span>
        <span>JOINs</span>
        <span>GROUP BY</span>
      </div>
    </div>
    <div class="skill-card reveal">
      <h3><span class="icon" style="background:rgba(74,255,139,0.1)">📈</span> Visualisation</h3>
      <p>Building clear, purposeful charts that tell a story. Every chart should answer one question in five seconds.</p>
      <div class="skill-tags">
        <span>Google Sheets Charts</span>
        <span>Power BI</span>
        <span>Combo Charts</span>
      </div>
    </div>
    <div class="skill-card reveal">
      <h3><span class="icon" style="background:rgba(255,184,74,0.1)">🧹</span> Data Cleaning</h3>
      <p>Health audits, duplicate detection, text standardisation, outlier assessment, and documenting every decision in a cleaning log.</p>
      <div class="skill-tags">
        <span>COUNTA</span>
        <span>TRIM</span>
        <span>Data Dictionaries</span>
        <span>Cleaning Logs</span>
      </div>
    </div>
  </div>
</section>

<!-- Projects -->
<section id="projects">
  <div class="section-label reveal">Portfolio</div>
  <h2 class="section-title reveal">Projects</h2>

  <!-- Project 1: Bank Churn -->
  <div class="project-card reveal">
    <div class="project-header">
      <div></div>
      <div class="project-status status-complete"><span class="status-dot"></span> Complete</div>
    </div>
    <div class="project-body">
      <h3>Bank Customer Churn Analysis</h3>
      <p class="description">Analysed 10,000 bank customer records to identify who is churning, where the risk is concentrated, and what early warning signs exist. Discovered that 3-4 product customers churn at 80-100% regardless of engagement, and the 46-60 age group churns at 2.5x the base rate across all markets.</p>

      <div class="project-stats">
        <div class="stat">
          <span class="stat-value">10,000</span>
          <span class="stat-label">Records analysed</span>
        </div>
        <div class="stat">
          <span class="stat-value">20.37%</span>
          <span class="stat-label">Base churn rate</span>
        </div>
        <div class="stat">
          <span class="stat-value">7</span>
          <span class="stat-label">Key findings</span>
        </div>
        <div class="stat">
          <span class="stat-value">4</span>
          <span class="stat-label">Visualisations</span>
        </div>
      </div>

      <div class="project-findings">
        <div class="finding">
          <strong>82-100% churn</strong>
          Customers with 3-4 products left at catastrophic rates, even when active.
        </div>
        <div class="finding">
          <strong>51.12% churn</strong>
          The 46-60 age group churns at 2.5x the base rate across all countries.
        </div>
        <div class="finding">
          <strong>31.63% churn</strong>
          Inactive customers with non-zero balances are the highest-volume risk group.
        </div>
        <div class="finding">
          <strong>7.58% churn</strong>
          Two-product customers are the retention sweet spot, the lowest churn of any product count.
        </div>
      </div>

      <div class="project-tech">
        <span>Google Sheets</span>
        <span>COUNTIFS</span>
        <span>INDIRECT</span>
        <span>Combo Charts</span>
        <span>Data Dictionary</span>
        <span>Cleaning Log</span>
      </div>

      <div class="project-links">
        <a href="https://github.com/oscareche/banking-customer-churn" target="_blank" class="btn-primary">View on GitHub ↗</a>
      </div>
    </div>
  </div>

  <!-- Placeholder: Future Project -->
  <div class="project-card project-placeholder reveal">
    <div class="placeholder-content">
      <div class="icon-large">🔬</div>
      <h3>Next project in progress</h3>
      <p>SQL analysis in BigQuery, targeting healthcare or fintech data</p>
    </div>
  </div>
</section>

